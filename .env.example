# ─────────────────────────────────────────────────────────────────────────────
# TRON-X — example environment variables
# Copy to .env and fill in. Blank or '#'-prefixed values are treated as unset.
# ─────────────────────────────────────────────────────────────────────────────

# ── Phase 37: Proactive Intelligence (Anticipation Engine + Sentinel) ────────
# PROACTIVE_ENABLED=true                 # master switch for briefings + sentinel
# PROACTIVE_MORNING_CRON=0 8 * * *       # morning briefing schedule
# PROACTIVE_EVENING_CRON=0 21 * * *      # evening wrap-up schedule
# PROACTIVE_SENTINEL_INTERVAL_SEC=180    # meeting/conflict/VIP-mail sweep cadence
# PROACTIVE_MEETING_LEAD_MIN=15          # "meeting in N min" alert window
# PROACTIVE_VIP_SENDERS=boss@co.com,bank # comma-separated; alerts on unread mail
# CONSOLIDATION_ENABLED=true             # nightly episodic→knowledge consolidation
# CONSOLIDATION_CRON=30 3 * * *
# CONSOLIDATION_RETENTION_DAYS=90        # episodes older than this are prunable
# CONSOLIDATION_PRUNE_ENABLED=false      # opt-in: actually delete old episodes
# DEFAULT_LOCATION=Hyderabad             # weather in briefings ("auto" = IP-based)

# ── WhatsApp Cloud API (Meta Graph API) ──────────────────────────────────────
# Set up at https://developers.facebook.com -> your App -> WhatsApp.
#
#   WHATSAPP_ACCESS_TOKEN       System-user / permanent access token (Bearer).
#   WHATSAPP_PHONE_NUMBER_ID    The phone-number ID that sends messages
#                               (NOT the display phone number).
#   WHATSAPP_BUSINESS_ACCOUNT_ID Optional WABA id.
#   WHATSAPP_APP_SECRET         App secret — used to validate the
#                               X-Hub-Signature-256 on inbound webhooks.
#                               REQUIRED in production; if unset the webhook
#                               accepts unverified payloads (dev only).
#   WHATSAPP_VERIFY_TOKEN       A string YOU choose; enter the same value in the
#                               Meta webhook config. Used for the GET handshake.
#   WHATSAPP_API_VERSION        Graph API version (default v21.0).
#   WHATSAPP_STORE_PATH         Where inbound messages are persisted.
#   WHATSAPP_STORE_MAX          Ring-buffer cap (oldest dropped past this).
#
# Webhook callback URL to register with Meta (must be public HTTPS):
#   https://YOUR_DOMAIN/api/whatsapp/webhook
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_API_VERSION=v21.0
WHATSAPP_STORE_PATH=memory/whatsapp_messages.json
WHATSAPP_STORE_MAX=2000

# ── WhatsApp SENDING backend ─────────────────────────────────────────────────
# "baileys" = open-source Node sidecar (whatsapp-bridge/), uses your own number,
#             no browser, no Business account, no templates, no 24h window.
# "cloud"   = Meta WhatsApp Business Cloud API (vars above).
WHATSAPP_BACKEND=baileys
WHATSAPP_BRIDGE_URL=http://127.0.0.1:8088
# Shared secret between TRON-X and the Node sidecar. Generate: openssl rand -hex 32
# Set the SAME value as WHATSAPP_BRIDGE_TOKEN in the sidecar's environment.
WHATSAPP_BRIDGE_TOKEN=
#
# In the sidecar's environment also set (so inbound messages reach TRON-X):
#   WHATSAPP_INGEST_URL=http://127.0.0.1:8000/api/whatsapp/bridge/ingest

# ── LLM Providers ────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
FIREWORKS_API_KEY=
OPENROUTER_API_KEY=

# ── Phase 3: Web Search ───────────────────────────────────────────────────────
# Primary: Serper.dev Google Search API — https://serper.dev (free tier: 2500 queries/mo)
SERPER_API_KEY=
# Optional fallback: Brave Search API — https://brave.com/search/api/
BRAVE_API_KEY=

# ── Phase 4: Computer Vision ──────────────────────────────────────────────────
# Vision LLM for VisualComputerAgent — Gemini 2.0 Flash recommended (set GEMINI_API_KEY above)
# Desktop control deps: pip install pyautogui mss Pillow --break-system-packages

# ── Home Assistant / IoT ─────────────────────────────────────────────────────
HA_URL=http://homeassistant.local:8123
HA_TOKEN=
HA_MQTT_BROKER=localhost
HA_MQTT_PORT=1883

# ── Supabase (optional persistent memory) ────────────────────────────────────
SUPABASE_URL=
SUPABASE_KEY=

# ── App Settings ─────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-in-production
ALLOWED_ORIGINS=*

# ── Phase 23: Context-Aware Dynamic Prompt Pruning ───────────────────────────
# "semantic" (default) = drop the lowest-relevance older turns first, always
#   keeping the system prompt + last 3 turns (RECENCY_ANCHOR).
# "fifo" = original behavior, drop oldest turns first regardless of relevance.
PRUNING_STRATEGY=semantic

# ── Phase 28: Proactive Cron Analytics & Diagnostic Self-Healing ─────────────
# Background job (via SchedulerAgent) that periodically checks CPU/RAM/disk
# (psutil) + SmartRouter circuit-breaker health, takes automated remediation
# actions, and logs every run to memory/cache/diagnostics.jsonl.
#
#   SELF_HEALING_ENABLED              Master on/off switch for the job.
#   SELF_HEALING_INTERVAL_SEC         How often to run the health check.
#   RAM_THRESHOLD_PCT                 RAM usage %% that triggers gc.collect()
#                                      + in-process cache clears.
#   DISK_THRESHOLD_PCT                Disk usage %% that triggers log trimming
#                                      + purge of conversation turns >30d old
#                                      (never touches remembered facts).
#   CIRCUIT_TRIP_REORDER_THRESHOLD    Number of simultaneously-tripped models
#                                      that triggers SmartRouter.bias_fallback_chain()
#                                      toward a healthy model (auto-reverts).
SELF_HEALING_ENABLED=true
SELF_HEALING_INTERVAL_SEC=300
RAM_THRESHOLD_PCT=85
DISK_THRESHOLD_PCT=90
CIRCUIT_TRIP_REORDER_THRESHOLD=3

# ── Phase 22: Local Intent Cache & Semantic Command Routing ──────────────────
# Caches high-confidence "safe" classifications (chat / iot only -- see
# SAFE_CACHEABLE_INTENTS in src/intelligence/intent_cache.py) keyed by
# embedding similarity, so paraphrases of a previously-seen command skip the
# keyword+LLM classification round-trip entirely. IoT cache hits also let
# nl_mapper skip its LLM fallback (with an entity-existence recheck against
# the current device list).
#
#   INTENT_CACHE_ENABLED        Master on/off switch. false = lookup() always
#                                returns None (instant no-op, original behavior).
#   INTENT_CACHE_SIM_THRESHOLD  Cosine-similarity cutoff for a cache hit (0-1).
#   INTENT_CACHE_TTL_DAYS       Entries older than this are evicted daily
#                                (and once at startup).
#
# Say "clear command cache" / "reset routines" to wipe the cache manually.
INTENT_CACHE_ENABLED=true
INTENT_CACHE_SIM_THRESHOLD=0.98
INTENT_CACHE_TTL_DAYS=30

# ── Phase 33: Encrypted Memory Backup & Disaster Recovery ────────────────────
# Daily (by default) encrypted snapshot of memory/chroma/ + memory/cache/
# session state to BACKUP_DIR, via src/system/backup.py. Restore with
# `python scripts/restore_backup.py <file> --passphrase ...`.
#
#   BACKUP_ENABLED            Master on/off switch. Default false (opt-in) --
#                               see src/system/backup.py docstring for why
#                               this defaults off rather than on.
#   BACKUP_PASSPHRASE         Required if BACKUP_ENABLED=true. Used to derive
#                               the encryption key (PBKDF2-HMAC-SHA256). If
#                               unset while enabled, backups stay disabled and
#                               a warning is logged at startup (no crash).
#   BACKUP_DIR                Where .tar.enc archives are written. Keep this
#                               outside the repo or gitignored (it contains
#                               all memory data) -- "backups/" is gitignored.
#   BACKUP_RETENTION_COUNT    Keep only the N most recent archives.
#   BACKUP_CRON               Cron expression for the scheduled backup job.
BACKUP_ENABLED=false
# BACKUP_PASSPHRASE=change-me
BACKUP_DIR=backups/
BACKUP_RETENTION_COUNT=7
BACKUP_CRON=0 3 * * *
